    {
      "name": "verify-login",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "// Extract access token from JSON response and store in active environment",
              "pm.test(\"Extract access_token\", function () {",
              "    pm.response.to.have.status(200);",
              "",
              "    let json;",
              "    try {",
              "        json = pm.response.json();",
              "    } catch (e) {",
              "        pm.expect.fail(\"Response is not valid JSON: \" + e.message);",
              "    }",
              "",
              "    const token = json.access_token || json.token || json.jwt || json.accessToken;",
              "    pm.expect(token, \"Expected an access token field in response body\").to.be.a(\"string\").and.not.be.empty;",
              "",
              "    pm.environment.set(\"access_token\", token);",
              "    if (json.token_type) {",
              "        pm.environment.set(\"token_type\", json.token_type);",
              "    }",
              "});",
              ""
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
