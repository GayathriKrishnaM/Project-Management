    {
      "name": "create_user",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status code is 2xx', function () {",
              "  pm.expect(pm.response.code).to.be.within(200, 299);",
              "});",
              "",
              "pm.test('Response is JSON (if body present)', function () {",
              "  pm.response.to.be.json;",
              "});",
              "",
              "pm.test('Response has user fields when present', function () {",
              "  const json = pm.response.json();",
              "  const fields = ['id', 'email', 'name', 'role'];",
              "",
              "  pm.expect(json).to.be.an('object');",
              "",
              "  fields.forEach((f) => {",
              "    if (Object.prototype.hasOwnProperty.call(json, f) && json[f] !== null) {",
              "      if (f === 'id') {",
              "        pm.expect([ 'string', 'number' ]).to.include(typeof json[f]);",
              "      } else {",
              "        pm.expect(json[f]).to.be.a('string');",
              "      }",
              "    }",
              "  });",
              "});",
              ""
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
